# Optional overrides. The tracker works out of the box with no env vars.

# Where to store the SQLite database (defaults to ./flightfinder.db).
# FLIGHTFINDER_DB=./flightfinder.db

# Number of concurrent Google Flights scrapes. Keep small; Google rate-limits.
# FLIGHTFINDER_CONCURRENCY=3

# fast-flights fetch mode: "common" (fast, primp-based) or "fallback" (Playwright).
# If you get blocked often, try "fallback" (requires `playwright install`).
# FLIGHTFINDER_FETCH_MODE=common

# Python log level for the CLI.
# FLIGHTFINDER_LOG=INFO
