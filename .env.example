# Amadeus Self-Service API credentials.
# Create a free account at https://developers.amadeus.com/, create a "Self-Service" app,
# and paste the key + secret here. Rename this file to .env.
AMADEUS_CLIENT_ID=
AMADEUS_CLIENT_SECRET=

# Optional. Set to "production" to use the paid production endpoint.
# Defaults to the free test environment.
AMADEUS_ENV=test

# Optional. Where to store the SQLite database.
FLIGHTFINDER_DB=./flightfinder.db
